generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  password     String
  name         String
  storeId      Int?
  storeName    String?
  lineUserId   String?  @unique
  lineNotify   Boolean  @default(false)
  createdAt    DateTime @default(now())
  orders       Order[]
  cartItems    CartItem[]
  notifyStores LineNotifyStore[]
  userTags     UserTag[]
}

model LineNotifyStore {
  id        Int    @id @default(autoincrement())
  userId    Int
  userName  String  @default("")
  storeId   Int
  user      User   @relation(fields: [userId], references: [id])

  @@unique([userId, storeId])
}

model Tag {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  userTags  UserTag[]
}

model UserTag {
  id     Int    @id @default(autoincrement())
  userId Int
  tagId  Int
  user   User   @relation(fields: [userId], references: [id])
  tag    Tag    @relation(fields: [tagId], references: [id])

  @@unique([userId, tagId])
}

model Product {
  id          Int       @id @default(autoincrement())
  storeId     Int
  storeName   String
  name        String
  description String
  price       Int
  saleDate    DateTime
  stock       Int
  imageUrl    String
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  orderItems  OrderItem[]
  cartItems   CartItem[]
}

model Order {
  id            Int         @id @default(autoincrement())
  storeId        Int
  total         Int
  paymentMethod String
  buyerName     String?
  buyerEmail    String?
  userId        Int?
  createdAt     DateTime    @default(now())
  items         OrderItem[]
  user          User?       @relation(fields: [userId], references: [id])
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([userId, productId])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  storeId   Int
  storeName String
  saleDate  DateTime
  quantity  Int
  unitPrice Int
  lineTotal Int
  order     Order    @relation(fields: [orderId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])
}
